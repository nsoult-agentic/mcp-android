{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/http.ts"],
  "project": ["src/**/*.ts"],
  "ignoreUnresolved": ["bun-types"],
  "ignoreBinaries": ["Xvfb"],
  "rules": {
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn"
  }
}
